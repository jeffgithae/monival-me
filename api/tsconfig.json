{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node10",
    "esModuleInterop": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/AI/Bots/**/*.ts",
    "src/AI/asr/**/*.ts",
    "src/AI/gemini/**/*.ts",
    "src/AI/openai/**/*.ts",
    "src/AI/phi/**/*.ts",
    "src/AI/utilities/**/*.ts",
    "src/AI/vectorstore/**/*.ts",
    "src/AI/whisper/**/*.ts"
  ]
}
