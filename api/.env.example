# PORT=3000
# MONGODB_URI=mongodb://localhost:27017/evidara -me
# JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=7d
# CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200
# FRONTEND_URL=http://localhost:4200
# BILLING_MOCK=true
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PROFESSIONAL=

# # ─── Cloud Storage OAuth ───────────────────────────────────────────────────────
# # Google Drive — https://console.cloud.google.com/apis/credentials
# # Create an OAuth 2.0 Client ID, add your domain to Authorized redirect URIs:
# # https://your-domain.com/documents?cloud_callback=1&provider=google_drive
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# # Dropbox — https://www.dropbox.com/developers/apps
# # Create an app, enable Files.content.read, add redirect URI:
# # https://your-domain.com/documents?cloud_callback=1&provider=dropbox
# DROPBOX_CLIENT_ID=
# DROPBOX_CLIENT_SECRET=

# # SharePoint / Microsoft Graph — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# # Register an app, add Files.Read.All permission, add redirect URI:
# # https://your-domain.com/documents?cloud_callback=1&provider=sharepoint
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=
# SHAREPOINT_TENANT_ID=common

# ─── Core ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/evidara-me

# JWT — generate a strong random secret, e.g.: openssl rand -hex 32
# Never commit a real secret. Access tokens are short-lived (8h) and carry a
# tokenVersion claim that's invalidated on password change.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# Field-level encryption key for sensitive DB fields (e.g. cloud storage OAuth
# client secrets). Generate with: openssl rand -hex 32
# Losing/rotating this key makes previously-encrypted fields unreadable.
ENCRYPTION_KEY=change-me-in-production

CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200
FRONTEND_URL=http://localhost:4200
APP_URL=http://localhost:4200

# ─── Caching (optional — falls back to in-memory if unset) ──────────────────
REDIS_URL=

# ─── Billing ──────────────────────────────────────────────────────────────────
BILLING_MOCK=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=

# ─── Outbound email (scheduled reports, notifications) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Evidara M&E" <noreply@evidara.app>

# ─── Cloud Storage OAuth (platform-level fallback) ───────────────────────────
# Orgs can supply their own OAuth app credentials via Settings → Cloud Storage,
# which are stored encrypted per-org in the database. These env vars are only
# used as a fallback for orgs that haven't configured their own.
#
# Google Drive — https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID, add your domain to Authorized redirect URIs:
# https://your-domain.com/documents?cloud_callback=1&provider=google_drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dropbox — https://www.dropbox.com/developers/apps
# Create an app, enable Files.content.read, add redirect URI:
# https://your-domain.com/documents?cloud_callback=1&provider=dropbox
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# SharePoint / Microsoft Graph — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Register an app, add Files.Read.All permission, add redirect URI:
# https://your-domain.com/documents?cloud_callback=1&provider=sharepoint
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=common